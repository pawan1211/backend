{
  "name": "nexusit-backend",
  "version": "1.0.0",
  "description": "NexusIT Consulting API – Node.js + Express + PostgreSQL",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start":   "node server.js",
    "dev":     "nodemon server.js",
    "migrate": "psql $DATABASE_URL -f db/schema.sql",
    "lint":    "eslint . --ext .js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@sendgrid/mail":    "^8.1.0",
    "@supabase/supabase-js": "^2.39.0",
    "axios":             "^1.6.5",
    "cors":              "^2.8.5",
    "dotenv":            "^16.4.1",
    "express":           "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet":            "^7.1.0",
    "morgan":            "^1.10.0",
    "pg":                "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
